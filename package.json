{
  "name": "domino-occidental",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "bun --cwd packages/backend dev",
    "dev:frontend": "bun --cwd packages/frontend dev",
    "build": "bun --cwd packages/frontend build",
    "test": "bun --cwd packages/backend test",
    "biome:check": "biome check",
    "lint": "biome check",
    "format": "biome format --write",
    "clean": "rm -rf node_modules packages/*/node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/bun": "^1.3.14",
    "typescript": "^5"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
